{
  "name": "thirteens-game",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "server": "node server/index.js",
    "dev:all": "node -e \"const {spawn}=require('child_process'); const cmds=['npm run server','npm run start']; cmds.forEach((c)=>{const p=spawn(c,{stdio:'inherit',shell:true}); p.on('exit',(code)=>process.exitCode=process.exitCode||code||0);});\"",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "ethers": "^6.16.0",
    "expo": "~54.0.33",
    "expo-haptics": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "uuid": "^13.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
