{
  "name": "thirteens-game",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "server": "node server/index.js",
    "dev:all": "node -e \"const {spawn}=require('child_process'); const cmds=['npm run server','npm run start']; cmds.forEach((c)=>{const p=spawn(c,{stdio:'inherit',shell:true}); p.on('exit',(code)=>process.exitCode=process.exitCode||code||0);});\"",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "preview:web": "npx serve dist"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@supabase/supabase-js": "^2.103.3",
    "@walletconnect/modal-react-native": "^1.1.0",
    "@walletconnect/react-native-compat": "^2.23.9",
    "@walletconnect/universal-provider": "^2.23.9",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "ethers": "^6.16.0",
    "expo": "~54.0.33",
    "expo-av": "~16.0.8",
    "expo-haptics": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-get-random-values": "~1.11.0",
    "react-native-modal": "^13.0.1",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.0",
    "uuid": "^13.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
