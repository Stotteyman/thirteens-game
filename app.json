{
  "expo": {
    "name": "thirteens-game",
    "slug": "thirteens-game",
    "description": "Tien Len (Thirteens) – multiplayer Vietnamese card game. Play against bots or compete in live wager matches.",
    "version": "1.0.0",
    "runtimeVersion": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "thirteens",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#093028"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.thirteens.tienlen",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Not used.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.thirteens.tienlen",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#093028"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": []
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "static",
      "name": "Tien Len",
      "shortName": "TienLen",
      "lang": "en",
      "themeColor": "#093028",
      "backgroundColor": "#093028"
    },
    "updates": {
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/placeholder-update-url"
    },
    "extra": {
      "eas": {
        "projectId": "replace-with-your-eas-project-id"
      }
    }
  }
}
