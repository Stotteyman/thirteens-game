# ── Client (Expo) ──────────────────────────────────────────────────────────────
# URL of your deployed Node server. Used by all platforms (iOS, Android, Web).
# Must start with https:// in production, wss:// is derived automatically.
EXPO_PUBLIC_SERVER_URL=http://localhost:8088

# Supabase project URL and public key for client OAuth + session.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_or_publishable_key

# ── Server (Node) ──────────────────────────────────────────────────────────────
# Supabase service-role key used by the Node server for DB/game orchestration.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Port the server listens on (default 8088)
PORT=8088

# Allowed CORS origin for HTTP. Set to your web app domain in production.
# Use * only in development.
APP_ORIGIN=*
